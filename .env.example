# Required for live metal (gold/silver) rates. Get a key at https://metalpriceapi.com
METALS_API_KEY=your_metalpriceapi_key_here

# Optional: secures cron that refreshes metal rates at 6am, 1pm, 8pm IST. Generate with: openssl rand -hex 32
# CRON_SECRET=your_cron_secret_here

# Required if using Genkit AI features. Get a key from Google AI Studio.
# GOOGLE_GENAI_API_KEY=your_google_genai_key_here
